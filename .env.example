NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_TEBEX_WEBSTORE_IDENTIFIER=your_webstore_identifier
TEBEX_PUBLIC_TOKEN=your_tebex_public_token
TEBEX_PRIVATE_KEY=your_tebex_private_key
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_REDIRECT_URI=http://localhost:3000/api/auth/discord/callback

# Hero section style: "1" (default), "2" (centered), "3" (minimal), "hidden"
NEXT_PUBLIC_HERO_STYLE=1

# Store branding
NEXT_PUBLIC_STORE_NAME=My Store

# Support
NEXT_PUBLIC_SUPPORT_EMAIL=support@yourstore.com

# Social links (leave empty to hide the icon)
NEXT_PUBLIC_DISCORD_URL=https://discord.gg/your-server
NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/your-account
NEXT_PUBLIC_TIKTOK_URL=https://tiktok.com/@your-account
NEXT_PUBLIC_TWITTER_URL=https://x.com/your-account
NEXT_PUBLIC_YOUTUBE_URL=https://youtube.com/@your-channel
NEXT_PUBLIC_GITHUB_URL=https://github.com/your-org
